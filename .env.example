# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/my_application"

# Session signing key. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="your_randomly_generated_string"

# SAML Service Provider entity ID -- must match your Duke SP registration exactly.
# This is always your production domain, even when developing locally.
SAML_SP_ENTITY_ID="https://myapp.duke.edu"

# App origin -- the URL where your app is currently reachable.
# Used to build the ACS callback URL ({ORIGIN}/api/auth/callback).
# For local dev use http://localhost:5173, for production use your real domain.
ORIGIN="http://localhost:5173"

# --- Certificate fallbacks (optional) ---
# Certificates are read from the certs/ directory by default.
# These env vars are only needed if you can't use files (e.g., some PaaS providers).
# SAML_SP_PRIVATE_KEY=""
# SAML_SP_CERTIFICATE=""
# SAML_IDP_CERT=""
